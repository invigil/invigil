{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.invigil/invigil",
  "description": "Grades repo legibility for newcomers and AI agents — an exact fix on every failing check.",
  "repository": {
    "url": "https://github.com/invigil/invigil",
    "source": "github"
  },
  "version": "1.7.0",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "invigil",
      "version": "1.7.0",
      "runtimeHint": "uvx",
      "runtimeArguments": [
        {
          "type": "named",
          "name": "--from",
          "value": "invigil[mcp]"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
